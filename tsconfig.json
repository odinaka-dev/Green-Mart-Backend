{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "typeRoots": ["./node_modules/@types", "./src/@types"],
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "moduleResolution": "nodenext",
    "resolveJsonModule": true,

    "types": ["node"],

    "skipLibCheck": true,
    "sourceMap": true
  }
}
