# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development
MONGO_URI=mongodb+srv://user:pass@cluster/greenmart   # a replica set is required for payment transactions (Atlas is one by default)
JWT_SECRET=your-jwt-secret
ADMIN_SECRET=your-admin-create-secret

# ─── Frontend / redirects ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Where Flutterwave redirects the customer after payment (defaults to FRONTEND_URL/checkout/callback)
PAYMENT_REDIRECT_URL=http://localhost:3000/checkout/callback

# ─── Flutterwave ──────────────────────────────────────────────────────────────
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxx-X
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxx-X
# The "Secret hash" you set in Flutterwave Dashboard → Settings → Webhooks.
# Flutterwave sends it verbatim in the `verif-hash` header on every webhook.
FLW_SECRET_HASH=your-webhook-secret-hash

# ─── Commerce ─────────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=NGN
# Tax as a fraction of (subtotal - discount). 0.075 = 7.5% VAT. 0 disables tax.
TAX_RATE=0

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
